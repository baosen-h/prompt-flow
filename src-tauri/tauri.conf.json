{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "prompt-flow",
  "version": "0.1.0",
  "identifier": "dev.promptflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "powershell -NoProfile -Command \"Set-Location -LiteralPath $env:INIT_CWD; npm run dev\"",
    "beforeBuildCommand": "powershell -NoProfile -Command \"Set-Location -LiteralPath $env:INIT_CWD; npm run build\""
  },
  "app": {
    "windows": [
      {
        "title": "prompt-flow",
        "width": 520,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
